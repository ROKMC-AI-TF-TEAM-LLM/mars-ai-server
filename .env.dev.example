# ============================================================
# 개발 노트북(Windows) 전용 .env 템플릿
# 사용: Copy-Item .env.dev.example .env   (dev_setup.ps1이 자동 수행)
# L40 운영 배포 시에는 .env.example을 기준으로 작성할 것
# ============================================================

# LLM: llama.cpp 개발 서버 (serving/start_llm_dev.ps1) — vLLM과 동일 계약
AX_BASE_URL=http://localhost:8000/v1
AX_MODEL_NAME=skt/A.X-4.0-Light
AX_API_KEY=EMPTY

# 임베딩/리랭커: GPU는 llama.cpp가 쓰므로 CPU로
EMBEDDING_SERVER_URL=http://localhost:8001/embed
EMBEDDING_DEVICE=cpu
EMBEDDING_MODEL_PATH=./models/bge-m3
RERANKER_SERVER_URL=http://localhost:8002/rerank
RERANKER_DEVICE=cpu
RERANKER_MODEL_PATH=./models/bge-reranker-v2-m3
RERANK_TOP_K=20
RERANK_TOP_N=5

# 벡터DB: Windows는 Milvus Lite 미지원 → Docker Milvus standalone (localhost)
MILVUS_LITE_PATH=http://localhost:19530
MILVUS_COLLECTION=company_docs

BM25_INDEX_PATH=./data/bm25_index
MAX_VERIFY_RETRY=1
HISTORY_MAX_TOKENS=1500
AUDIT_LOG_PATH=./data/audit_log.jsonl
LOG_LEVEL=DEBUG
STREAM_TEXT_INTERVAL_MS=200

# 오프라인 강제 (모델은 로컬 경로에서만)
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
LANGGRAPH_CLI_NO_ANALYTICS=1
